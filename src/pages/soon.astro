---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Próximamente">
    <main class="flex flex-col justify-center items-center h-screen gap-6 m-auto px-4 bg-red-950 text-center">
        <div class="text-center">
            <h1 class="text-5xl font-semibold text-slate-200 mb-4">Próximamente</h1>
            <p class="text-slate-400 mb-8 max-w-sm text-lg">Estamos trabajando en algo especial. Vuelve pronto y síguenos en Instagram.</p>
            
            <div class="flex justify-center gap-2 mb-8">
                <div class="w-3 h-3 bg-slate-400 rounded-full animate-pulse"></div>
                <div class="w-3 h-3 bg-slate-400 rounded-full animate-pulse" style="animation-delay: 0.2s"></div>
                <div class="w-3 h-3 bg-slate-400 rounded-full animate-pulse" style="animation-delay: 0.4s"></div>
            </div>

            <a href="/" class="inline-block px-6 py-2 bg-slate-800 text-white rounded hover:bg-slate-700 transition-colors">
                Volver al inicio
            </a>
            <a href="https://instagram.com/rrnews.icbvina" class="inline-block px-6 py-2 bg-slate-800 text-white rounded hover:bg-slate-700 transition-colors">
                Seguir en Instagram
            </a>
        </div>
    </main>
</Layout>
