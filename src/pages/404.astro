---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Ups!">
    <main class="flex flex-col justify-center items-center h-screen gap-6 m-auto px-4 bg-red-950">
        <div class="text-center">
            <h1 class="text-8xl font-light text-slate-300 mb-2">404</h1>
            <h2 class="text-3xl font-semibold text-slate-200 mb-4">No Encontrado</h2>
            <p class="text-slate-400 mb-8 max-w-sm">La página que buscas no existe o ha sido movida.</p>
            <a href="/" class="inline-block px-6 py-2 bg-slate-100 text-black rounded hover:bg-slate-700 transition-colors">
                Volver al inicio
            </a>
        </div>
    </main>
</Layout>