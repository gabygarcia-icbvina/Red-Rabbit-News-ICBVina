---
export const prerender = false
import Layout from '../../layouts/Layout.astro'
import { supabase, setAuthCookies } from '../../lib/supabase'

const redirectTo = Astro.url.searchParams.get('redirect') ?? '/admin'

// Si ya está logueado (tiene cookies), redirige al panel
const hasValidSession = Astro.cookies.has('sb-access-token') && Astro.cookies.has('sb-refresh-token')
if (hasValidSession) return Astro.redirect('/admin')

// Manejo del POST
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const email    = form.get('email')?.toString() ?? ''
  const password = form.get('password')?.toString() ?? ''

  const { data, error } = await supabase.auth.signInWithPassword({ email, password })

  if (error || !data.session) {
    return Astro.redirect('/admin/login?error=1')
  }

  // Guardar la sesión en cookies httpOnly
  setAuthCookies(Astro.cookies, {
    access_token: data.session.access_token,
    refresh_token: data.session.refresh_token,
  })
  return Astro.redirect(redirectTo)
}

const hasError = Astro.url.searchParams.get('error')
---

<Layout title="Admin — Login">
  <main class="min-h-screen bg-slate-950 flex items-center justify-center px-4">
    <div class="w-full max-w-sm">

      <div class="mb-8 text-center">
        <p class="text-red-400 text-sm font-semibold uppercase tracking-widest mb-2">Red Rabbit News</p>
        <h1 class="text-2xl font-bold text-white">Acceso editorial</h1>
        <p class="text-slate-400 text-sm mt-2">Solo para miembros del equipo</p>
      </div>

      {hasError && (
        <div class="mb-4 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3 text-sm text-red-400">
          Credenciales incorrectas. Intenta de nuevo.
        </div>
      )}

      <form method="POST" class="space-y-4">
        <div>
          <label class="block text-sm text-slate-400 mb-1.5">Correo</label>
          <input
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-xl bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-white placeholder-slate-600 focus:border-red-500/50 focus:outline-none transition"
            placeholder="admin@redrabbit.cl"
          />
        </div>

        <div>
          <label class="block text-sm text-slate-400 mb-1.5">Contraseña</label>
          <input
            name="password"
            type="password"
            required
            autocomplete="current-password"
            class="w-full rounded-xl bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-white placeholder-slate-600 focus:border-red-500/50 focus:outline-none transition"
            placeholder="••••••••"
          />
        </div>

        <button
          type="submit"
          class="w-full rounded-full bg-red-500 py-3 text-sm font-semibold text-white transition hover:bg-red-400 mt-2">
          Entrar
        </button>
      </form>
      <div class="mt-6 flex items-center gap-3">
        <div class="h-px flex-1 bg-slate-800"></div>
        <span class="text-xs text-slate-600">o</span>
        <div class="h-px flex-1 bg-slate-800"></div>
        </div>

        <a
        href={`/admin/oauth/google?redirect=${encodeURIComponent(redirectTo)}`}
        class="mt-4 w-full flex items-center justify-center gap-3 rounded-full border border-slate-800 bg-slate-900 py-3 text-sm font-semibold text-white transition hover:border-slate-600">
        <svg class="h-4 w-4" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continuar con Google
        </a>
    </div>
  </main>
</Layout>