---
export const prerender = false
import Layout from '../../../layouts/Layout.astro'
import { supabase } from '../../../lib/supabase'

// Aprobar / eliminar
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('action')?.toString()
  const commentId = form.get('comment_id')?.toString()

  if (commentId && action === 'approve') {
    await supabase.from('comments').update({ approved: true }).eq('id', commentId)
  } else if (commentId && action === 'delete') {
    await supabase.from('comments').delete().eq('id', commentId)
  }
  return Astro.redirect('/admin/comments')
}

const filter = Astro.url.searchParams.get('filter') ?? 'pending'

let query = supabase
  .from('comments')
  .select('*, articles(title, slug)')
  .order('created_at', { ascending: false })

if (filter === 'pending') query = query.eq('approved', false)
else if (filter === 'approved') query = query.eq('approved', true)

const { data: comments } = await query
---

<Layout title="Comentarios — Admin">
  <div class="min-h-screen bg-slate-950 text-white">
    <aside class="fixed inset-y-0 left-0 w-60 bg-slate-900 border-r border-slate-800 flex flex-col">
      <div class="px-6 py-5 border-b border-slate-800">
        <p class="text-red-400 text-xs font-bold uppercase tracking-widest">Red Rabbit</p>
        <p class="text-white font-semibold text-sm mt-0.5">Panel editorial</p>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        {[
          { href: '/admin', label: 'Dashboard', icon: '▦' },
          { href: '/admin/articles', label: 'Artículos', icon: '✎' },
          { href: '/admin/categories', label: 'Categorías', icon: '⊞' },
          { href: '/admin/authors', label: 'Autores', icon: '◎' },
          { href: '/admin/comments', label: 'Comentarios', icon: '☰' },
        ].map(item => (
          <a
            href={item.href}
            class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition ${
              Astro.url.pathname === item.href ? 'bg-slate-800 text-white' : 'text-slate-400 hover:text-white hover:bg-slate-800'
            }`}
          >
            <span>{item.icon}</span>{item.label}
          </a>
        ))}
      </nav>
      <div class="px-3 py-4 border-t border-slate-800">
        <a href="/admin/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-slate-500 hover:text-red-400 hover:bg-slate-800 transition">
          <span>⏻</span> Cerrar sesión
        </a>
      </div>
    </aside>

    <main class="ml-60 p-8">
      <div class="mb-6">
        <h1 class="text-2xl font-bold">Comentarios</h1>
        <p class="text-slate-400 text-sm mt-1">Modera los comentarios del periódico</p>
      </div>

      <!-- Filtros -->
      <div class="flex gap-2 mb-6">
        {[
          { value: 'pending', label: 'Pendientes' },
          { value: 'approved', label: 'Aprobados' },
          { value: 'all', label: 'Todos' },
        ].map(f => (
          <a
            href={`/admin/comments?filter=${f.value}`}
            class={`px-4 py-1.5 rounded-full text-sm font-medium transition ${
              filter === f.value ? 'bg-red-500 text-white' : 'bg-slate-800 text-slate-400 hover:text-white'
            }`}
          >
            {f.label}
          </a>
        ))}
      </div>

      <div class="space-y-3">
        {comments?.map(comment => (
          <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-white font-semibold text-sm">{comment.author_name}</span>
                  <span class="text-slate-600 text-xs">en</span>
                  <a
                    href={`/admin/articles/${comment.article_id}`}
                    class="text-red-400 hover:text-red-300 text-xs transition"
                  >
                    {(comment.articles as any)?.title ?? 'Artículo eliminado'}
                  </a>
                  <span class="text-slate-600 text-xs">·</span>
                  <span class="text-slate-500 text-xs">
                    {new Date(comment.created_at).toLocaleDateString('es-CL')}
                  </span>
                </div>
                <p class="text-slate-300 text-sm leading-relaxed">{comment.content}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                {!comment.approved && (
                  <form method="POST">
                    <input type="hidden" name="comment_id" value={comment.id} />
                    <input type="hidden" name="action" value="approve" />
                    <button
                      type="submit"
                      class="text-xs bg-green-500/10 text-green-400 hover:bg-green-500/20 transition px-3 py-1.5 rounded-lg font-medium"
                    >
                      ✓ Aprobar
                    </button>
                  </form>
                )}
                <form method="POST">
                  <input type="hidden" name="comment_id" value={comment.id} />
                  <input type="hidden" name="action" value="delete" />
                  <button
                    type="submit"
                    onclick="return confirm('¿Eliminar comentario?')"
                    class="text-xs bg-red-500/10 text-red-400 hover:bg-red-500/20 transition px-3 py-1.5 rounded-lg font-medium"
                  >
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
          </div>
        ))}
        {!comments?.length && (
          <div class="text-center py-16 text-slate-500">
            No hay comentarios {filter === 'pending' ? 'pendientes' : ''}.
          </div>
        )}
      </div>
    </main>
  </div>
</Layout>
