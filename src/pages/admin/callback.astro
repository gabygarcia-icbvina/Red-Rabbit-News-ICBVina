---
export const prerender = false
---

<!-- Este script corre en el cliente, lee el token del hash y lo manda al servidor -->
<script>
  import { createClient } from '@supabase/supabase-js'

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )

  const { data, error } = await supabase.auth.getSessionFromUrl()
  const session = data?.session
  const params = new URLSearchParams(window.location.search)
  const requestedRedirect = params.get('redirect')
  const returnTo = requestedRedirect?.startsWith('/') ? requestedRedirect : '/admin'

  if (session) {
    // Manda los tokens al servidor para guardarlos en cookies httpOnly
    const response = await fetch('/admin/set-session', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        access_token:  session.access_token,
        refresh_token: session.refresh_token,
      }),
    })

    if (response.ok) {
      window.location.href = returnTo
    } else {
      window.location.href = '/admin/login?error=1'
    }
  } else {
    window.location.href = '/admin/login?error=1'
  }
</script>