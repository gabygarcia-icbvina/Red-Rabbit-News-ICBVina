---
export const prerender = false
import Layout from '../../../layouts/Layout.astro'
import { supabase } from '../../../lib/supabase'

const status = Astro.url.searchParams.get('status') ?? 'all'

let query = supabase
  .from('articles')
  .select('id, title, slug, status, created_at, category, image_url, author_id')
  .order('created_at', { ascending: false })

if (status !== 'all') query = query.eq('status', status)

const { data: articles, error } = await query

// Buscar nombres de categorías en batch (category es texto/uuid, no foreign key)
const categoryIds = [...new Set(articles?.map(a => a.category).filter(Boolean))]
const { data: categoriesData } = categoryIds.length
  ? await supabase.from('categories').select('id, name, color').in('id', categoryIds)
  : { data: [] }

const categoryMap = Object.fromEntries(categoriesData?.map(c => [c.id, c]) ?? [])
---

<Layout title="Artículos — Admin">
  <div class="min-h-screen bg-slate-950 text-white">
    <aside class="fixed inset-y-0 left-0 w-60 bg-slate-900 border-r border-slate-800 flex flex-col">
      <div class="px-6 py-5 border-b border-slate-800">
        <p class="text-red-400 text-xs font-bold uppercase tracking-widest">Red Rabbit</p>
        <p class="text-white font-semibold text-sm mt-0.5">Panel editorial</p>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        {[
          { href: '/admin', label: 'Dashboard', icon: '▦' },
          { href: '/admin/articles', label: 'Artículos', icon: '✎' },
          { href: '/admin/categories', label: 'Categorías', icon: '⊞' },
          { href: '/admin/authors', label: 'Autores', icon: '◎' },
          { href: '/admin/comments', label: 'Comentarios', icon: '☰' },
        ].map(item => (
          <a
            href={item.href}
            class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition ${
              Astro.url.pathname === item.href
                ? 'bg-slate-800 text-white'
                : 'text-slate-400 hover:text-white hover:bg-slate-800'
            }`}
          >
            <span>{item.icon}</span>{item.label}
          </a>
        ))}
      </nav>
      <div class="px-3 py-4 border-t border-slate-800">
        <a href="/admin/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-slate-500 hover:text-red-400 hover:bg-slate-800 transition">
          <span>⏻</span> Cerrar sesión
        </a>
      </div>
    </aside>

    <main class="ml-60 p-8">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold">Artículos</h1>
          <p class="text-slate-400 text-sm mt-1">{articles?.length ?? 0} artículos encontrados</p>
        </div>
        <a href="/admin/articles/new" class="bg-red-500 hover:bg-red-400 transition text-white text-sm font-semibold px-4 py-2.5 rounded-full">
          + Nuevo artículo
        </a>
      </div>

      {error && (
        <div class="mb-4 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3 text-sm text-red-400">
          Error al cargar artículos: {error.message}
        </div>
      )}

      <!-- Filtros -->
      <div class="flex gap-2 mb-6">
        {[
          { value: 'all', label: 'Todos' },
          { value: 'published', label: 'Publicados' },
          { value: 'draft', label: 'Borradores' },
        ].map(f => (
          <a
            href={`/admin/articles?status=${f.value}`}
            class={`px-4 py-1.5 rounded-full text-sm font-medium transition ${
              status === f.value
                ? 'bg-red-500 text-white'
                : 'bg-slate-800 text-slate-400 hover:text-white'
            }`}
          >
            {f.label}
          </a>
        ))}
      </div>

      <div class="bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="text-left px-6 py-3 text-slate-400 font-medium">Título</th>
              <th class="text-left px-6 py-3 text-slate-400 font-medium">Categoría</th>
              <th class="text-left px-6 py-3 text-slate-400 font-medium">Estado</th>
              <th class="text-left px-6 py-3 text-slate-400 font-medium">Fecha</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {articles?.map(article => {
              const cat = categoryMap[article.category]
              return (
                <tr class="border-b border-slate-800/50 hover:bg-slate-800/30 transition">
                  <td class="px-6 py-3 text-white font-medium max-w-xs truncate">
                    {article.title}
                  </td>
                  <td class="px-6 py-3">
                    {cat ? (
                      <span
                        class="text-xs font-semibold px-2 py-1 rounded-full"
                        style={`background:${cat.color}20;color:${cat.color}`}
                      >
                        {cat.name}
                      </span>
                    ) : <span class="text-slate-600">—</span>}
                  </td>
                  <td class="px-6 py-3">
                    <span class={`text-xs font-semibold px-2 py-1 rounded-full ${
                      article.status === 'published'
                        ? 'bg-green-500/10 text-green-400'
                        : 'bg-yellow-500/10 text-yellow-400'
                    }`}>
                      {article.status === 'published' ? 'Publicado' : 'Borrador'}
                    </span>
                  </td>
                  <td class="px-6 py-3 text-slate-400">
                    {new Date(article.created_at).toLocaleDateString('es-CL')}
                  </td>
                  <td class="px-6 py-3 flex items-center gap-2 justify-end">
                    <a
                      href={`/admin/articles/${article.id}`}
                      class="text-xs text-slate-400 hover:text-white bg-slate-800 hover:bg-slate-700 transition px-3 py-1.5 rounded-lg"
                    >
                      Editar
                    </a>
                    <button
                      data-delete={article.id}
                      class="text-xs text-red-400 hover:text-red-300 bg-red-500/10 hover:bg-red-500/20 transition px-3 py-1.5 rounded-lg"
                    >
                      Eliminar
                    </button>
                  </td>
                </tr>
              )
            })}
            {!articles?.length && (
              <tr>
                <td colspan="5" class="px-6 py-12 text-center text-slate-500">
                  No hay artículos {status !== 'all' ? `con estado "${status}"` : ''} todavía.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </main>
  </div>
</Layout>

<script>
  document.querySelectorAll('[data-delete]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.delete
      if (!confirm('¿Eliminar este artículo?')) return
      const res = await fetch(`/api/admin/articles/${id}`, { method: 'DELETE' })
      if (res.ok) window.location.reload()
      else alert('Error al eliminar')
    })
  })
</script>