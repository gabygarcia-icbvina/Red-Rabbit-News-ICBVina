---
export const prerender = false
import Layout from '../../../layouts/Layout.astro'
import { supabase } from '../../../lib/supabase'
import ArticleEditor from '../../../components/admin/ArticleEditor'

const { slug } = Astro.params

const [{ data: article }, { data: categories }] = await Promise.all([
  supabase.from('articles').select('*').eq('slug', slug).single(),
  supabase.from('categories').select('id, name, color').order('name'),
])

if (!article) return Astro.redirect('/admin/articles')
---

<Layout title={`Editar: ${article.title} — Admin`}>
  <div class="min-h-screen bg-slate-950 text-white">
    <aside class="fixed inset-y-0 left-0 w-60 bg-slate-900 border-r border-slate-800 flex flex-col">
      <div class="px-6 py-5 border-b border-slate-800">
        <p class="text-red-400 text-xs font-bold uppercase tracking-widest">Red Rabbit</p>
        <p class="text-white font-semibold text-sm mt-0.5">Panel editorial</p>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        {[
          { href: '/admin', label: 'Dashboard', icon: '▦' },
          { href: '/admin/articles', label: 'Artículos', icon: '✎' },
          { href: '/admin/categories', label: 'Categorías', icon: '⊞' },
          { href: '/admin/authors', label: 'Autores', icon: '◎' },
          { href: '/admin/comments', label: 'Comentarios', icon: '☰' },
        ].map(item => (
          <a href={item.href} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition">
            <span>{item.icon}</span>{item.label}
          </a>
        ))}
      </nav>
      <div class="px-3 py-4 border-t border-slate-800">
        <a href="/admin/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-slate-500 hover:text-red-400 hover:bg-slate-800 transition">
          <span>⏻</span> Cerrar sesión
        </a>
      </div>
    </aside>

    <main class="ml-60 p-8">
      <div class="mb-6 flex items-center gap-3">
        <a href="/admin/articles" class="text-slate-500 hover:text-white transition text-sm">← Artículos</a>
        <span class="text-slate-700">/</span>
        <h1 class="text-xl font-bold truncate max-w-sm">{article.title}</h1>
      </div>

      <ArticleEditor
        client:load
        article={article}
        categories={categories ?? []}
        authors={[]}
      />
    </main>
  </div>
</Layout>